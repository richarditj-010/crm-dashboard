# ============================================================
#  CONFIGURAÇÃO DO CRM DASHBOARD - MODELO (.env.example)
# ------------------------------------------------------------
#  COMO USAR:
#  1. Faça uma cópia deste arquivo com o nome ".env"
#  2. Preencha os valores reais (sem aspas)
#  3. NUNCA compartilhe o arquivo .env - ele contém suas senhas/tokens
# ============================================================

# --- RD Station CRM (obrigatório a partir da Etapa 2) ---
# Token de instância gerado no painel do RD Station CRM.
# (Eu te mando o passo a passo para pegar este código.)
RD_CRM_TOKEN=cole_aqui_o_token_do_rd_station

# URL base da API do CRM (não precisa alterar)
RD_CRM_BASE_URL=https://crm.rdstation.com/api/v1

# --- Banco de dados ---
# Caminho do arquivo SQLite local (Fase 1)
DATABASE_URL=sqlite:///./data/crm.db

# --- IA / Claude (só será usado na Fase 3) ---
ANTHROPIC_API_KEY=cole_aqui_a_chave_da_claude_quando_chegarmos_na_fase_3

# --- Servidor local ---
APP_HOST=127.0.0.1
APP_PORT=8000
